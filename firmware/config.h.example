// ═══════════════════════════════════════════════════════════
//   WAVEGUARD — config.h.example
//   Central configuration for ESP32 marine buoy firmware.
//   Copy this file to config.h, fill in your values, and
//   never commit config.h to version control.
// ═══════════════════════════════════════════════════════════
#ifndef CONFIG_H
#define CONFIG_H

// ── Device Identity ──────────────────────────────────────────
#define BUOY_ID          "WG-01"          // Unique buoy identifier (max 32 chars)
#define FIRMWARE_VERSION "4.1.0"

// ── WiFi Credentials ─────────────────────────────────────────
// Replace with the SSID and password of the network shared with your laptop.
#define WIFI_SSID        "YOUR_WIFI_SSID"
#define WIFI_PASSWORD    "YOUR_WIFI_PASSWORD"

// Milliseconds to wait for a WiFi connection before giving up
#define WIFI_TIMEOUT_MS  15000

// ── Backend API ──────────────────────────────────────────────
// Replace SERVER_IP with the IPv4 address of the laptop running FastAPI.
// Find it with `ipconfig` (Windows) or `ifconfig`/`ip addr` (Linux/macOS).
#define SERVER_IP        "192.168.1.100"
#define SERVER_PORT      8005
#define API_ENDPOINT     "/api/buoy"

// Full URL is constructed at runtime: http://SERVER_IP:SERVER_PORT/API_ENDPOINT
// HTTP request timeout in milliseconds
#define HTTP_TIMEOUT_MS  8000

// ── Buoy API Key ─────────────────────────────────────────────
// Must match the WAVEGUARD_BUOY_API_KEY environment variable on the backend.
// Set this to a long random string shared between the buoy and server.
#define BUOY_API_KEY     "YOUR_BUOY_API_KEY"

// ── Sensor — MPU-6050 Accelerometer / Gyroscope ──────────────
// Default I2C address when AD0 pin is LOW (0x69 when AD0 is HIGH)
#define MPU6050_ADDR     0x68

// I2C pins (default ESP32 hardware I2C)
#define SDA_PIN          21
#define SCL_PIN          22

// Number of accelerometer samples averaged per transmission
#define SAMPLE_COUNT     20

// Interval between individual samples (ms) — 20 samples × 10 ms = 200 ms window
#define SAMPLE_INTERVAL_MS 10

// ── Wave Classification Thresholds (g-force) ─────────────────
// Must match backend classify_buoy() in backend/main.py
#define THRESHOLD_CALM       0.05f   // below → CALM   → NORMAL on backend
#define THRESHOLD_MODERATE   0.10f   // below → MODERATE → WATCH on backend
                                     // at or above → HIGH WAVE → WARNING

// ── Wave Speed & ETA ─────────────────────────────────────────
// Approximate wave propagation speeds (m/s) per sea state
#define SPEED_CALM_MS        1.0f
#define SPEED_MODERATE_MS    2.0f
#define SPEED_HIGH_WAVE_MS   4.0f

// Distance from buoy to shore in metres (default: 80 km)
#define DISTANCE_TO_SHORE_M  80000.0f

// ── Transmission Interval ────────────────────────────────────
// How often to send a reading to the backend (ms).
// Keep ≥ 2000 ms to avoid flooding the API.
#define SEND_INTERVAL_MS     5000

// ── GPS (Optional — TinyGPS++ over UART2) ────────────────────
// Comment out GPS_ENABLED if no GPS module is attached.
#define GPS_ENABLED

#ifdef GPS_ENABLED
  #define GPS_BAUD       9600
  #define GPS_RX_PIN     16    // ESP32 GPIO16 → GPS TX
  #define GPS_TX_PIN     17    // ESP32 GPIO17 → GPS RX (unused but required)
  // Seconds to wait for a valid GPS fix before sending without coordinates
  #define GPS_FIX_TIMEOUT_S  10
#endif

// ── GSM / SIM800L (Optional fallback when WiFi is unavailable) ──
// Uncomment GSM_ENABLED to compile in GSM support.
// Requires TinyGSM library and a SIM card with data plan.
// #define GSM_ENABLED

#ifdef GSM_ENABLED
  #define GSM_APN        "YOUR_APN"        // e.g. "airtelgprs.com"
  #define GSM_USER       ""                // leave blank if not required
  #define GSM_PASS       ""
  #define GSM_RX_PIN     26               // ESP32 GPIO → SIM800L TX
  #define GSM_TX_PIN     27               // ESP32 GPIO → SIM800L RX
  #define GSM_BAUD       9600
#endif

// ── Serial Debug ─────────────────────────────────────────────
// Set to 1 to enable verbose Serial output; 0 to suppress for production.
#define DEBUG_SERIAL     1
#define SERIAL_BAUD      115200

#endif // CONFIG_H
